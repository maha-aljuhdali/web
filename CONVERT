<body>
  <DIV class="main">
    <script >

function inchesConverter(){
document.converter.centimeters.value = (document.converter.inches.value *2.54) 
}
function centimetersConverter(){
document.converter.inches.value = (document.converter.centimeters.value /2.54)
}
</script>
  <br><br>
<h2>measurements convnter</h2>
<br>

<h3>length convertion</h3>
<form name="converter">
inches (in): <input type="text" name="inches" onChange="inchesConverter()">
centimeters (cm): <input type="text" name="centimeters" onChange="centimetersConverter()"><br />
</form><br><br>
</DIV>
</body>
